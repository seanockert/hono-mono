{
  "name": "server",
  "version": "0.0.1",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "migrate": "bun run src/lib/migrate.ts",
    "migrate:remote": "wrangler d1 migrations apply hono-mono --remote",
    "deploy": "bunx wrangler deploy",
    "lint": "oxlint --ignore-path ../.gitignore .",
    "format": "oxfmt --ignore-path ../.gitignore .",
    "format:check": "oxfmt --ignore-path ../.gitignore --check ."
  },
  "dependencies": {
    "better-auth": "^1.5.5",
    "hono": "^4.12.8",
    "kysely": "^0.28.12",
    "kysely-d1": "^0.4.0",
    "shared": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
