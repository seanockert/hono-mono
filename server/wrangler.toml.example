name = "hono-mono-app"
main = "dist/index.js"
compatibility_date = "2025-02-13"
compatibility_flags = ["nodejs_compat"]

[vars]
# Public URLs - Update with your actual deployment URLs
BETTER_AUTH_URL = "https://your-app-name.workers.dev"
CLIENT_URL = "https://your-client-name.pages.dev"
# BETTER_AUTH_SECRET is configured as a Wrangler secret

[[d1_databases]]
binding = "DATABASE"
database_name = "hono-mono"
database_id = "xxx"
