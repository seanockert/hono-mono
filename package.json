{
  "name": "hono-auth",
  "version": "0.0.2",
  "description": "A monorepo with Bun, Hono, Vue, and Better Auth",
  "keywords": [
    "better-auth",
    "bun",
    "hono",
    "monorepo",
    "vite",
    "vue"
  ],
  "homepage": "",
  "license": "MIT",
  "author": "Sean Ockert",
  "workspaces": [
    "./server",
    "./client",
    "./shared"
  ],
  "scripts": {
    "dev": "bun run dev.ts",
    "build": "cd shared && bun run build && cd ../client && bun run build",
    "deploy": "cd server && bun run deploy && cd ../client && bun run deploy",
    "postinstall": "cd shared && bun run build",
    "lint": "oxlint --ignore-path .gitignore .",
    "format": "oxfmt --ignore-path .gitignore .",
    "format:check": "oxfmt --ignore-path .gitignore --check ."
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@hono/zod-validator": "^0.7.6",
    "better-auth": "^1.5.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "bun-types": "latest"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  }
}
