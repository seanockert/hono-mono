{
  "name": "hono-auth",
  "version": "0.0.1",
  "description": "A monorepo with Bun, Hono, Vue, and Better Auth",
  "author": "Sean Ockert",
  "license": "MIT",
  "homepage": "",
  "workspaces": [
    "./server",
    "./client",
    "./shared"
  ],
  "scripts": {
    "dev:client": "cd client && bun run dev",
    "dev:server": "cd server && bun run dev",
    "dev:shared": "cd shared && bun run dev",
    "dev": "concurrently \"bun run dev:shared\" \"bun run dev:server\" \"bun run dev:client\"",
    "build:client": "cd client && bun run build",
    "build:shared": "cd shared && bun run build",
    "build:server": "cd server && bun run build",
    "build": "bun run build:shared && bun run build:server && bun run build:client",
    "deploy:client": "cd client && bun run deploy",
    "deploy:server": "cd server && bun run deploy",
    "deploy:all": "bun run deploy:server && bun run deploy:client",
    "postinstall": "bun run build:shared && bun run build:server"
  },
  "keywords": [
    "bun",
    "hono",
    "vue",
    "vite",
    "better-auth",
    "monorepo"
  ],
  "devDependencies": {
    "bun-types": "latest",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20260128.0",
    "@hono/zod-validator": "^0.7.6",
    "better-auth": "^1.4.17",
    "zod": "^4.3.6"
  }
}
