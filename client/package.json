{
  "name": "client",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:prod": "vue-tsc -b && vite build --mode production",
    "preview": "vite preview",
    "deploy": "bun run build:prod && bunx wrangler pages deploy dist --project-name=hono-mono-client",
    "deploy:dev": "bun run build && bunx wrangler pages deploy dist --project-name=hono-mono-client",
    "lint": "oxlint --ignore-path ../.gitignore .",
    "format": "oxfmt --ignore-path ../.gitignore .",
    "format:check": "oxfmt --ignore-path ../.gitignore --check ."
  },
  "dependencies": {
    "@kitbag/router": "^0.24.0",
    "better-auth": "^1.5.5",
    "shared": "workspace:*",
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vue-tsc": "^3.2.6"
  }
}
